# For Neon, use the pooled connection string for the application runtime.
# Add this value in Vercel Project Settings > Environment Variables.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Optional: use the provider's direct connection for Prisma CLI migrations.
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST:PORT/DATABASE?sslmode=require"
